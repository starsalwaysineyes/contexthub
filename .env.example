CONTEXT_HUB_PORT=4040
CONTEXT_HUB_DATA_DIR=./var/data
CONTEXT_HUB_DATABASE_PATH=./var/data/contexthub.db

CONTEXT_HUB_ENABLE_EMBEDDINGS=true
CONTEXT_HUB_EMBEDDING_BASE_URL=https://cloud.infini-ai.com/maas/v1
CONTEXT_HUB_EMBEDDING_API_KEY=
CONTEXT_HUB_EMBEDDING_MODEL=bge-m3

CONTEXT_HUB_ENABLE_RERANK=false
CONTEXT_HUB_RERANK_BASE_URL=https://cloud.infini-ai.com/maas/v1
CONTEXT_HUB_RERANK_API_KEY=
CONTEXT_HUB_RERANK_MODEL=bge-reranker-v2-m3

CONTEXT_HUB_DEFAULT_LIMIT=8
CONTEXT_HUB_CANDIDATE_LIMIT=40
CONTEXT_HUB_RERANK_TOP_N=8
CONTEXT_HUB_LEXICAL_WEIGHT=0.45
CONTEXT_HUB_VECTOR_WEIGHT=0.35
CONTEXT_HUB_MANUAL_WEIGHT=0.15
CONTEXT_HUB_RECENCY_WEIGHT=0.05
